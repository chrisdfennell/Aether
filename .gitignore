# Connect IQ Build Outputs
bin/
*.prg
*.iq

# Private Developer Keys (NEVER commit these!)
*.der
*.pem
*.key
developer_key.der

# IDE and Editor local settings
.vscode/tasks.json
.vscode/launch.json
.vscode/settings.json
.settings/
.project
.pydevproject

# System temporary files
Thumbs.db
Desktop.ini
.DS_Store

# Local/temporary script files
compress.ps1
*temp*

# Keep GitHub community-health files: "TEMPLATE" contains "temp", so the
# case-insensitive *temp* rule above would otherwise ignore them.
!.github/PULL_REQUEST_TEMPLATE.md
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/*

# Local build configurations
build_config.json
